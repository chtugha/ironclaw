{
  "bundles": {
    "messaging": {
      "display_name": "Messaging Channels",
      "description": "Discord, Telegram, Slack, and WhatsApp channels",
      "extensions": [
        "channels/discord",
        "channels/telegram",
        "channels/slack",
        "channels/whatsapp",
        "channels/feishu"
      ],
      "shared_auth": null
    },
    "home": {
      "display_name": "Home Use",
      "description": "Local tools for home use: browser automation, calendar, notes, and file search",
      "extensions": [
        "mcp-servers/playwright",
        "tools/caldav",
        "tools/local_notes"
      ],
      "shared_auth": null
    }
  }
}
